# ============================================================
# TalentHub Live - Environment Configuration Template
# ============================================================
# Copy this file to .env and fill in the values
# NEVER commit .env to version control!

# ============================================================
# CRITICAL: Database Configuration
# ============================================================
# PostgreSQL connection string (REQUIRED for production)
# Format: postgresql://username:password@host:port/database
# Example: postgresql://talenthub_user:secure_password@localhost:5432/talenthub_db
DATABASE_URL=postgresql://user:password@localhost:5432/talenthub

# ============================================================
# CRITICAL: Security Configuration
# ============================================================
# SECRET_KEY: MUST be set for JWT token signing (32+ characters)
# Generate with: openssl rand -hex 32
# NEVER use the default value in production!
SECRET_KEY=3ad3f4f0f84ba1a19c55b2bf5d838480e0c76d99111fe2d8fedc5e751891b53a

# Google OAuth Client ID (REQUIRED for authentication)
# Get from: https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com

# ============================================================
# CORS Configuration (Security)
# ============================================================
# Comma-separated list of allowed origins
# Production: Set to your actual frontend domain(s)
# Development: Can be left empty to use defaults
ALLOWED_ORIGINS=https://yourdomain.com,https://www.yourdomain.com

# ============================================================
# Admin Configuration
# ============================================================
# Comma-separated list of admin email addresses
# Users with these emails will automatically get admin role
ADMIN_EMAILS=admin@example.com,another.admin@example.com

# ============================================================
# Optional: Application Configuration
# ============================================================
# Environment (development, staging, production)
ENVIRONMENT=production

# Log level (DEBUG, INFO, WARNING, ERROR, CRITICAL)
LOG_LEVEL=INFO

# ============================================================
# Optional: Monitoring & Error Tracking
# ============================================================
# Sentry DSN for error tracking (optional but recommended)
# SENTRY_DSN=https://your-sentry-dsn@sentry.io/project-id

# ============================================================
# Optional: Email Configuration (for notifications)
# ============================================================
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your-email@gmail.com
# SMTP_PASSWORD=your-app-password
# SMTP_FROM=noreply@yourdomain.com

# ============================================================
# SECURITY CHECKLIST
# ============================================================
# [ ] SECRET_KEY is set and is at least 32 characters
# [ ] SECRET_KEY is randomly generated (not the default)
# [ ] DATABASE_URL uses PostgreSQL (not SQLite in production)
# [ ] GOOGLE_CLIENT_ID is set correctly
# [ ] ALLOWED_ORIGINS only includes your production domains
# [ ] ADMIN_EMAILS contains only trusted email addresses
# [ ] .env file is in .gitignore (NEVER commit to git)
# [ ] Database credentials are strong and unique
# [ ] File permissions are restrictive (chmod 600 .env)
