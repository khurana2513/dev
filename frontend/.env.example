# ============================================================
# TalentHub Frontend — Environment Configuration Template
# ============================================================
# Vite reads .env files at BUILD TIME, not runtime.
# Variables MUST be prefixed with VITE_ to be exposed to the app.
#
# Files and their contexts:
#   .env                → loaded always (base, don't put secrets here)
#   .env.development    → loaded when running `vite` (dev server)
#   .env.production     → loaded when running `vite build`
#   .env.local          → loaded always, NEVER committed to git
#
# For this project, just use .env.local with everything in it.
# .env.local is gitignored by Vite by default.
#
# On Vercel: set these in the Vercel dashboard per-environment.
# ============================================================

# ============================================================
# API BASE URL — where the backend lives
# ============================================================
VITE_API_BASE=https://hi-test.up.railway.app
# PRODUCTION Vercel env:  https://hi-test.up.railway.app
# DEVELOPMENT Vercel env (dev branch): https://dev-api.blackmonkey.in
# LOCAL dev server:       http://localhost:5000

# ============================================================
# GOOGLE OAUTH CLIENT ID (public, safe to expose)
# ============================================================
VITE_GOOGLE_CLIENT_ID=193498438302-apr7tr3mskq4cmhm564mloa2hi0p2hoq.apps.googleusercontent.com
# Same value for dev and prod unless you created a separate OAuth client.
