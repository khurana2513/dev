{
  "name": "abacus-frontend",
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "node ./node_modules/vite/bin/vite.js build",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest run --coverage",
    "e2e": "playwright test",
    "e2e:headed": "playwright test --headed",
    "e2e:ui": "playwright test --ui",
    "e2e:debug": "playwright test --debug",
    "e2e:public": "playwright test --project=public",
    "e2e:student": "playwright test --project=student",
    "e2e:admin": "playwright test --project=admin",
    "e2e:report": "playwright show-report",
    "e2e:login:student": "playwright open --channel chrome --save-storage=e2e/.auth/student.json http://localhost:3000",
    "e2e:login:admin": "playwright open --channel chrome --save-storage=e2e/.auth/admin.json http://localhost:3000"
  },
  "dependencies": {
    "@capacitor/core": "^8.2.0",
    "@cashfreepayments/cashfree-js": "^1.0.6",
    "@codetrix-studio/capacitor-google-auth": "^3.4.0-rc.4",
    "@hookform/resolvers": "^3.10.0",
    "@tanstack/react-query": "^5.60.5",
    "date-fns": "^3.6.0",
    "framer-motion": "^11.18.2",
    "html2canvas": "^1.4.1",
    "jspdf": "^4.2.1",
    "lucide-react": "^0.453.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-hook-form": "^7.55.0",
    "wouter": "^3.3.5",
    "zod": "^3.24.2",
    "zustand": "^5.0.11"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^20.14.0",
    "@types/react": "^18.3.11",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.7.0",
    "@vitest/ui": "^4.1.4",
    "autoprefixer": "^10.4.20",
    "dotenv": "^17.4.2",
    "jsdom": "^29.0.2",
    "postcss": "^8.4.47",
    "sharp": "^0.34.5",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.6.3",
    "vite": "^7.3.0",
    "vite-plugin-pwa": "^1.2.0",
    "vitest": "^4.1.4"
  }
}
