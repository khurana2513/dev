# ============================================================
# TalentHub Backend — Environment Configuration Template
# ============================================================
# Copy this to .env and fill in real values.
# .env is GITIGNORED — never commit it.
#
# There are two contexts where this runs:
#   PRODUCTION  → Railway (auto-deploys from main branch)
#   DEVELOPMENT → Mac Mini or localhost (dev branch)
#
# ============================================================
# CONTEXT FLAG
# ============================================================
APP_ENV=development
# Values: development | staging | production
# Controls: CORS defaults, log verbosity, rate limits
# Railway sets this to "production" via the Variables panel.

# ============================================================
# DATABASE
# ============================================================
DATABASE_URL=postgresql://user:password@host:port/dbname
# PRODUCTION:  Railway injects this automatically via shared variable.
# DEVELOPMENT: Use your Neon connection string:
#   postgresql://neondb_owner:<password>@<host>.neon.tech/neondb?sslmode=require
# LOCAL:       postgresql://postgres:postgres@localhost:5432/talenthub_dev

# ============================================================
# JWT / AUTH
# ============================================================
SECRET_KEY=replace_this_with_at_least_32_random_characters
# Generate a strong key: openssl rand -hex 32
# DEV and PROD must use DIFFERENT secret keys.
# If you share a key, dev JWTs will be valid on production and vice versa.

# ============================================================
# GOOGLE OAUTH
# ============================================================
GOOGLE_CLIENT_ID=193498438302-xxxx.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-xxxxxxxxxxxxxxxxxxxx
# You can reuse the same Google OAuth client for dev (just add localhost
# and dev domain to "Authorised JavaScript Origins" in Google Console).
# Or create a separate OAuth client for dev — cleaner but not required.

# ============================================================
# CORS — Origins that can call this API
# ============================================================
ALLOWED_ORIGINS=https://th.blackmonkey.in,https://dev.th.blackmonkey.in,http://localhost:5173
# PRODUCTION Railway value: https://th.blackmonkey.in
# DEVELOPMENT Mac Mini value: https://dev.th.blackmonkey.in,http://localhost:5173
# LOCAL only: http://localhost:5173,http://localhost:3000
# DevelopmentConfig in config.py auto-adds localhost if ALLOWED_ORIGINS is empty.

# ============================================================
# ADMIN EMAILS
# ============================================================
ADMIN_EMAILS=ayushkhurana47@gmail.com,sunitakhurana15061977@gmail.com,macmini2513@gmail.com

# ============================================================
# LOGGING
# ============================================================
LOG_LEVEL=INFO
# Development: DEBUG (verbose) | Production: INFO (clean)

# ============================================================
# PAYMENT GATEWAYS (optional for dev — set to dummy values)
# ============================================================
RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxx
RAZORPAY_KEY_SECRET=xxxxxxxxxxxxxxxxxxxx
CASHFREE_APP_ID=xxxxxxxxxxxx
CASHFREE_SECRET_KEY=xxxxxxxxxxxxxxxxxxxx
# Use TEST keys from Razorpay/Cashfree dashboard for dev.
# Never use live/production payment keys in dev.

# ============================================================
# PLAYWRIGHT / PDF (Railway sets these)
# ============================================================
PLAYWRIGHT_BROWSERS_PATH=0
# On Mac Mini/MacBook: leave unset or set to empty.
# Playwright will use system default browser path.
